                    <Style><FontFamily>Arial</FontFamily><FontSize>8pt</FontSize></Style>
                    <Hidden>=IIF(First(Fields!SgstAmount.Value,"InvoiceDS")=0, true, false)</Hidden>
                  </Textbox>
                  <Textbox Name="SgstValue">
