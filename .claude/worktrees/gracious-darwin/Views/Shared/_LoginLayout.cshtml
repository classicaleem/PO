<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - SIM</title>

    <!-- Google Font: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <!-- AdminLTE 4 -->
    <link rel="stylesheet" href="~/css/vendor/adminlte.min.css">
    
    <style>
        :root {
            --primary-color: #6366f1;
            --primary-hover: #4f46e5;
        }
        
        body {
            font-family: 'Inter', sans-serif;
            background: url('/images/login-bg.png') no-repeat center center fixed;
            background-size: cover;
        body {
            font-family: 'Inter', sans-serif;
            background: url('/images/login-bg.png') no-repeat center center fixed;
            background-size: cover;
            margin: 0;
            padding: 0;
            min-height: 100vh; /* Allow growth */
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden; /* Prevent horizontal scroll */
            overflow-y: auto;   /* Allow vertical scroll */
        }

        /* Dark Overlay */
        body::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(5px);
            z-index: 1;
            position: fixed; /* Fixed to cover updated scrollable area */
        }

        .login-box {
            position: relative;
            z-index: 2;
            width: 100%;
            max-width: 480px;
            padding: 20px;
            margin: auto; /* Center in scrollable area */
        }

        /* Glass Card Refined */
        .card-glass {
            background: rgba(15, 23, 42, 0.65);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.36);
            padding: 48px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        /* Shine effect */
        .card-glass::before {
            content: '';
            position: absolute;
            top: 0; left: -50%; width: 50%; height: 100%;
            background: linear-gradient(to right, transparent, rgba(255,255,255,0.03), transparent);
            transform: skewX(-25deg);
            pointer-events: none;
        }

        .brand-logo {
            max-width: 160px;
            max-height: 100px;
            width: auto;
            height: auto;
            margin-bottom: 2rem;
            object-fit: contain;
            filter: drop-shadow(0 0 20px rgba(99, 102, 241, 0.4));
            display: inline-block;
            mix-blend-mode: screen;
        }

        .login-title {
            color: white;
            font-weight: 700;
            font-size: 2rem;
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        .login-subtitle {
            color: #94a3b8;
            margin-bottom: 2.5rem;
        }

        .form-control {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            padding: 16px;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(15, 23, 42, 0.8);
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.2);
            color: white;
        }
        
        .form-control::placeholder {
            color: #64748b;
        }

        .input-group-text {
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-right: none;
            color: #94a3b8;
        }

        .btn-login {
            background: linear-gradient(to right, #6366f1, #8b5cf6);
            border: none;
            padding: 16px;
            border-radius: 12px;
            color: white;
            font-weight: 600;
            font-size: 1.1rem;
            letter-spacing: 0.5px;
            width: 100%;
            margin-top: 1.5rem;
            transition: all 0.3s;
            box-shadow: 0 4px 6px -1px rgba(99, 102, 241, 0.3);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(99, 102, 241, 0.4);
            background: linear-gradient(to right, #4f46e5, #7c3aed);
            color: white;
        }

        .form-check-input {
            background-color: rgba(15, 23, 42, 0.6);
            border-color: rgba(255, 255, 255, 0.2);
        }
        
        .form-check-input:checked {
            background-color: var(--primary-color);
            border-color: var(--primary-color);
        }
        
        .form-check-label {
            color: #cbd5e1;
            font-size: 0.9rem;
        }

        .text-danger {
            font-size: 0.875rem;
            color: #fca5a5 !important;
            margin-top: 5px;
            display: block;
            text-align: left;
        }

        /* Mobile Responsiveness */
        @@media (max-width: 576px) {
            .card-glass {
                padding: 30px 20px; /* Reduced Padding */
                border-radius: 16px;
            }
            
            .brand-logo {
                max-width: 120px; /* Smaller Logo */
                margin-bottom: 1.5rem;
            }

            .login-title {
                font-size: 1.5rem;
            }

            .login-box {
                padding: 15px; /* Minimal padding around card */
            }
        }
    </style>
</head>
<body>
    <div class="login-box">
        @RenderBody()
    </div>

    <!-- Bootstrap 5 -->
    <script src="~/js/vendor/bootstrap.bundle.min.js"></script>
</body>
</html>


