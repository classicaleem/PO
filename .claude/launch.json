{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "SmartPO (HTTP)",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "SmartPO.csproj", "--launch-profile", "http"],
      "port": 5260
    },
    {
      "name": "SmartPO (HTTPS)",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "SmartPO.csproj", "--launch-profile", "https"],
      "port": 7240
    },
    {
      "name": "SmartPO (Watch + HTTP)",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["watch", "run", "--project", "SmartPO.csproj", "--launch-profile", "http"],
      "port": 5260
    }
  ]
}
