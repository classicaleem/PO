@{
    ViewData["Title"] = "Invoices";
}

<link rel="stylesheet" href="~/css/vendor/ag-grid.css" />
<link rel="stylesheet" href="~/css/vendor/ag-theme-alpine.css" />

<!-- Compact Page Header -->
<div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
    <div>
        <h5 class="mb-0 text-primary"><i class="fas fa-receipt me-2"></i>Invoices</h5>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Create" class="btn btn-sm btn-primary">
            <i class="fas fa-plus me-1"></i>New Invoice
        </a>
    </div>
</div>

<!-- Filters & Grid -->
<div class="card shadow-sm border-0">
     <div class="card-body p-2 bg-light border-bottom">
        <div class="row g-2 align-items-center">
            <div class="col-md-2">
                <label class="form-label small fw-bold mb-0">From Date</label>
                <input type="date" id="fromDate" class="form-control form-control-sm"  lang="en-GB">
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-bold mb-0">To Date</label>
                <input type="date" id="toDate" class="form-control form-control-sm"  lang="en-GB">
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button onclick="loadData()" class="btn btn-sm btn-secondary w-100" style="margin-top: 20px;">
                    <i class="fas fa-sync-alt me-1"></i>Load Data
                </button>
            </div>
            <div class="col-md-6 d-flex justify-content-end align-items-end">
                <input type="text" id="quickFilter" oninput="onQuickFilterChanged()" class="form-control form-control-sm w-50" placeholder="Global Search..." />
            </div>
        </div>
    </div>
    <div class="card-body p-0">
         <div id="myGrid" class="ag-theme-alpine" style="height: 600px; width: 100%;"></div>
    </div>
</div>

@section Scripts {
    <script src="~/js/vendor/ag-grid-community.min.js"></script>
    <script>
        let gridApi;

        // Set default dates (last 6 months)
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date();
            const sixMonthsAgo = new Date();
            sixMonthsAgo.setMonth(today.getMonth() - 6);
            document.getElementById('toDate').valueAsDate = today;
            document.getElementById('fromDate').valueAsDate = sixMonthsAgo;
            loadData();
        });

        const gridOptions = {
            columnDefs: [
                { field: "invoiceNumber", headerName: "Invoice #", width: 150, filter: 'agTextColumnFilter', sortable: true, checkboxSelection: true, headerCheckboxSelection: true },
                { field: "internalPoCode", headerName: "PO Code", width: 150, filter: 'agTextColumnFilter', sortable: true },
                { field: "customerName", headerName: "Customer", width: 200, filter: 'agTextColumnFilter', sortable: true },
                { 
                    field: "invoiceDate", 
                    headerName: "Date", 
                    width: 130, 
                    sortable: true,
                    valueFormatter: params => {
                        if (!params.value) return '';
                        const date = new Date(params.value);
                        return ('0'+date.getDate()).slice(-2)+'-'+('0'+(date.getMonth()+1)).slice(-2)+'-'+date.getFullYear();
                    }
                },
                { field: "totalQuantity", headerName: "Qty", width: 100, type: 'numericColumn', sortable: true },
                { 
                    field: "grandTotal", 
                    headerName: "Amount", 
                    width: 150, 
                    type: 'numericColumn', 
                    sortable: true,
                    valueFormatter: params => '₹' + params.value.toLocaleString('en-IN', { minimumFractionDigits: 2 }),
                     cellStyle: { fontWeight: 'bold' } 
                },
                {
                    field: "isPaid",
                    headerName: "Status",
                    width: 120,
                    sortable: true,
                    cellRenderer: params => {
                        return params.value
                            ? `<span class="badge bg-success rounded-0">Paid</span>`
                            : `<span class="badge bg-warning text-dark rounded-0">Unpaid</span>`;
                    }
                },
                {
                    headerName: "Actions",
                    width: 210,
                    cellRenderer: params => {
                        const id = params.data.invoiceId;
                        let buttons = `
                            <div class="d-flex align-items-center gap-1">
                                <a href="/Invoices/Details/${id}" class="btn btn-outline-info btn-sm py-0 px-1" title="View"><i class="fas fa-eye"></i></a>
                                <select onchange="downloadInvoice(this, ${id})" class="form-select form-select-sm py-0" style="width:105px;font-size:11px;height:26px;">
                                    <option value="">⬇ PDF...</option>
                                    <option value="original">Original</option>
                                    <option value="duplicate">Duplicate</option>
                                    <option value="triplicate">Triplicate</option>
                                </select>
                        `;

                        // Role Check
                        const isAdmin = @(User.IsInRole("Admin").ToString().ToLower());

                        if (isAdmin) {
                            buttons += `
                                <a href="/Invoices/Edit/${id}" class="btn btn-outline-primary btn-sm p-1" title="Edit"><i class="fas fa-edit"></i></a>
                                <a href="/Invoices/Delete/${id}" class="btn btn-outline-danger btn-sm p-1" title="Delete"><i class="fas fa-trash"></i></a>
                            `;
                        }
                        buttons += `</div>`;
                        return buttons;
                    }
                }
            ],
            defaultColDef: {
                resizable: true,
                sortable: true,
                filter: true
            },
            pagination: true,
            paginationPageSize: 20,
            paginationPageSizeSelector: [20, 50, 100],
            rowHeight: 40,
            headerHeight: 40,
            animateRows: true,
            rowSelection: 'multiple', // Fix warning
        };

        const gridDiv = document.querySelector('#myGrid');
        gridApi = agGrid.createGrid(gridDiv, gridOptions);

        function loadData() {
            const from = document.getElementById('fromDate').value;
            const to   = document.getElementById('toDate').value;
            if (gridApi) { gridApi.showLoadingOverlay(); }
            fetch('/Invoices/GetInvoicesJson?fromDate=' + from + '&toDate=' + to)
                .then(response => response.json())
                .then(data => { gridApi.setGridOption('rowData', data); })
                .catch(error => { console.error('Error:', error); gridApi.setGridOption('rowData', []); });
        }


        function onQuickFilterChanged() {
            gridApi.setGridOption('quickFilterText', document.getElementById('quickFilter').value);
        }

        function downloadInvoice(select, id) {
            const type = select.value;
            if (!type) return;
            window.open(`/Invoices/DownloadPdf/${id}?copyType=${type}`, '_blank');
            select.value = ''; // reset to placeholder after opening
        }
    </script>
}
