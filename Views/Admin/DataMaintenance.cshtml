@{
    ViewData["Title"] = "Data Maintenance";
}

<!-- Page Header -->
<div class="page-header" style="background: linear-gradient(135deg, #c0392b 0%, #e74c3c 100%);">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="fas fa-database me-3"></i>Data Maintenance</h1>
            <p class="mb-0 opacity-75">Manage transactional data — Admin only</p>
        </div>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row mt-4">
    <!-- Info Card -->
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-bottom">
                <h5 class="mb-0"><i class="fas fa-info-circle text-primary me-2"></i>What will be cleared</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Table</th>
                            <th>Action</th>
                            <th>Note</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><code>InvoiceItems</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">Invoice line items</td>
                        </tr>
                        <tr>
                            <td><code>DeliveryChallanItems</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">DC line items</td>
                        </tr>
                        <tr>
                            <td><code>QuotationItems</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">Quotation line items</td>
                        </tr>
                        <tr>
                            <td><code>PurchaseOrderItems</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">PO line items</td>
                        </tr>
                        <tr>
                            <td><code>Invoices</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">All invoices</td>
                        </tr>
                        <tr>
                            <td><code>DeliveryChallans</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">All delivery challans</td>
                        </tr>
                        <tr>
                            <td><code>Quotations</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">All quotations</td>
                        </tr>
                        <tr>
                            <td><code>PurchaseOrders</code></td>
                            <td><span class="badge bg-danger">DELETED &amp; RESEEDED</span></td>
                            <td class="text-muted small">All purchase orders</td>
                        </tr>
                        <tr class="table-success">
                            <td><code>Customers</code></td>
                            <td><span class="badge bg-success">PRESERVED</span></td>
                            <td class="text-muted small">Not touched</td>
                        </tr>
                        <tr class="table-success">
                            <td><code>IndianStates</code></td>
                            <td><span class="badge bg-success">PRESERVED</span></td>
                            <td class="text-muted small">Not touched</td>
                        </tr>
                        <tr class="table-success">
                            <td><code>Users</code></td>
                            <td><span class="badge bg-success">PRESERVED</span></td>
                            <td class="text-muted small">Not touched</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Action Card -->
    <div class="col-lg-5">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-exclamation-triangle me-2"></i>Danger Zone</h5>
            </div>
            <div class="card-body">
                <p class="text-muted mb-3">
                    This action will <strong>permanently delete</strong> all Purchase Orders, Invoices, Delivery Challans,
                    and Quotations along with their line items. Identity counters will be reset to 1.
                </p>
                <p class="text-muted mb-4">
                    <i class="fas fa-shield-alt text-success me-1"></i>
                    <strong>Customers, Users, and Indian States will NOT be affected.</strong>
                </p>

                <div class="alert alert-warning py-2 mb-4">
                    <i class="fas fa-clock me-1"></i>
                    <strong>This action cannot be undone.</strong> Make sure you have a database backup before proceeding.
                </div>

                <!-- Confirmation button triggers modal -->
                <button type="button" class="btn btn-danger w-100 btn-lg" data-bs-toggle="modal" data-bs-target="#confirmModal">
                    <i class="fas fa-trash-alt me-2"></i>Clear All Transactional Data
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Confirmation Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1" aria-labelledby="confirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmModalLabel">
                    <i class="fas fa-exclamation-triangle me-2"></i>Confirm Data Clear
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="mb-2">You are about to delete <strong>all transactional records</strong>:</p>
                <ul class="mb-3">
                    <li>All Purchase Orders &amp; their items</li>
                    <li>All Invoices &amp; their items</li>
                    <li>All Delivery Challans &amp; their items</li>
                    <li>All Quotations &amp; their items</li>
                </ul>
                <div class="alert alert-danger mb-0 py-2">
                    <strong>This CANNOT be undone.</strong> Are you absolutely sure?
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-1"></i>Cancel
                </button>
                <form asp-controller="Admin" asp-action="TruncateAllTables" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt me-1"></i>Yes, Clear All Data
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
