@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var completionRate = Model.TotalPOs > 0 ? (double)Model.CompletedPOs / Model.TotalPOs * 100 : 0;
}

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="fas fa-tachometer-alt me-3"></i>Dashboard</h1>
            <p class="mb-0 opacity-75">Welcome back! Here's an overview of your SIM PO Management System.</p>
        </div>
        <div class="text-end d-none d-md-block">
            <small class="opacity-75">@DateTime.Now.ToString("dddd, dd MMM yyyy")</small>
        </div>
    </div>
</div>

<!-- KPI Row 1 -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <i class="fas fa-file-invoice-dollar"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Total Purchase Orders</span>
                <span class="info-box-number fs-3 fw-bold">@Model.TotalPOs</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: @completionRate%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);"></div>
                </div>
                <small class="text-muted">@Model.CompletedPOs completed, @Model.PendingPOs pending</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); color: white;">
                <i class="fas fa-clock"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Pending POs</span>
                <span class="info-box-number fs-3 fw-bold">@Model.PendingPOs</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: @(Model.TotalPOs > 0 ? (double)Model.PendingPOs / Model.TotalPOs * 100 : 0)%; background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);"></div>
                </div>
                <small class="text-muted">Needs completion</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;">
                <i class="fas fa-receipt"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Total Invoices</span>
                <span class="info-box-number fs-3 fw-bold">@Model.TotalInvoices</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: @(Model.TotalInvoices > 0 ? (double)(Model.TotalInvoices - Model.UnpaidInvoices) / Model.TotalInvoices * 100 : 0)%; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);"></div>
                </div>
                <small class="text-muted">@Model.UnpaidInvoices unpaid</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
                <i class="fas fa-indian-rupee-sign"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Unpaid Amount</span>
                <span class="info-box-number fs-4 fw-bold">@Model.UnpaidAmount.ToString("N0")</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: 100%; background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);"></div>
                </div>
                <small class="text-danger fw-semibold">Outstanding payments</small>
            </div>
        </div>
    </div>
</div>

<!-- KPI Row 2 -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #434343 0%, #000000 100%); color: white;">
                <i class="fas fa-chart-line"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Total PO Revenue</span>
                <span class="info-box-number fs-4 fw-bold">@Model.TotalPoAmount.ToString("N0")</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar bg-dark" style="width: 100%;"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: white;">
                <i class="fas fa-check-circle"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Paid Amount</span>
                <span class="info-box-number fs-4 fw-bold">@Model.PaidAmount.ToString("N0")</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar bg-success" style="width: @(Model.TotalInvoiceAmount > 0 ? (double)Model.PaidAmount / (double)Model.TotalInvoiceAmount * 100 : 0)%;"></div>
                </div>
                <small class="text-success fw-semibold">Received payments</small>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #0052D4 0%, #6FB1FC 100%); color: white;">
                <i class="fas fa-users"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Active Customers</span>
                <span class="info-box-number fs-3 fw-bold">@Model.ActiveCustomers</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: 100%; background: linear-gradient(135deg, #0052D4 0%, #6FB1FC 100%);"></div>
                </div>
                <a asp-controller="Customers" asp-action="Index" class="text-decoration-none"><small>View all</small></a>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-lg-3">
        <div class="info-box bg-white">
            <span class="info-box-icon" style="background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%); color: white;">
                <i class="fas fa-file-alt"></i>
            </span>
            <div class="info-box-content">
                <span class="info-box-text text-muted">Quotations</span>
                <span class="info-box-number fs-3 fw-bold">@Model.TotalQuotations</span>
                <div class="progress mt-2" style="height: 4px;">
                    <div class="progress-bar" style="width: 100%; background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);"></div>
                </div>
                <a asp-controller="Quotations" asp-action="Index" class="text-decoration-none"><small>View all</small></a>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row 1: Monthly Trend + PO Status -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="fas fa-chart-bar me-2 text-primary"></i>Monthly PO & Invoice Trend
                </h3>
            </div>
            <div class="card-body">
                <canvas id="monthlyTrendChart" height="280"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="fas fa-chart-pie me-2 text-success"></i>PO Status
                </h3>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="poStatusChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row 2: Top Customers + Payment Status -->
<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="fas fa-trophy me-2 text-warning"></i>Top 5 Customers by Amount
                </h3>
            </div>
            <div class="card-body">
                <canvas id="topCustomersChart" height="280"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card h-100">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="fas fa-money-check-alt me-2 text-info"></i>Payment Status
                </h3>
            </div>
            <div class="card-body d-flex align-items-center justify-content-center">
                <canvas id="paymentStatusChart" height="250"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Recent Data Row -->
<div class="row g-4 mb-4">
    <!-- Recent Purchase Orders -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">
                    <i class="fas fa-clock me-2 text-primary"></i>Recent Purchase Orders
                </h3>
                <a asp-controller="PurchaseOrders" asp-action="Index" class="btn btn-sm btn-primary">
                    View All <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentPOs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>PO Number</th>
                                    <th>Customer</th>
                                    <th class="text-end">Amount</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var po in Model.RecentPOs)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@po.PoId" class="fw-semibold text-decoration-none">
                                                @po.PoNumber
                                            </a>
                                        </td>
                                        <td>@po.CustomerName</td>
                                        <td class="text-end fw-semibold">@po.PoAmount.ToString("N0")</td>
                                        <td>@po.CreatedDate.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            @if (po.IsCompleted)
                                            {
                                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Done</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Pending</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                        <p class="text-muted mb-0">No purchase orders yet</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Invoices -->
    <div class="col-lg-6">
        <div class="card h-100">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="card-title mb-0">
                    <i class="fas fa-receipt me-2 text-success"></i>Recent Invoices
                </h3>
                <a asp-controller="Invoices" asp-action="Index" class="btn btn-sm btn-success">
                    View All <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentInvoices.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>Customer</th>
                                    <th class="text-end">Amount</th>
                                    <th>Date</th>
                                    <th>Payment</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in Model.RecentInvoices)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.InvoiceId" class="fw-semibold text-decoration-none">
                                                @inv.InvoiceNumber
                                            </a>
                                        </td>
                                        <td>@inv.CustomerName</td>
                                        <td class="text-end fw-semibold">@inv.GrandTotal.ToString("N0")</td>
                                        <td>@inv.InvoiceDate.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            @if (inv.IsPaid)
                                            {
                                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Unpaid</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-file-invoice fa-3x text-muted mb-3"></i>
                        <p class="text-muted mb-0">No invoices yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Attention Section: Unpaid Invoices -->
@if (Model.UnpaidInvoicesList.Any())
{
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-danger">
                <div class="card-header bg-danger bg-opacity-10">
                    <h3 class="card-title mb-0 text-danger">
                        <i class="fas fa-exclamation-triangle me-2"></i>Unpaid Invoices Requiring Attention (@Model.UnpaidInvoicesList.Count)
                    </h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>Invoice #</th>
                                    <th>PO Number</th>
                                    <th>Customer</th>
                                    <th class="text-end">Amount</th>
                                    <th>Invoice Date</th>
                                    <th>Days Overdue</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in Model.UnpaidInvoicesList)
                                {
                                    var daysOverdue = (DateTime.Now - inv.InvoiceDate).Days;
                                    var rowClass = daysOverdue > 30 ? "table-danger" : daysOverdue > 15 ? "table-warning" : "";
                                    <tr class="@rowClass">
                                        <td>
                                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.InvoiceId" class="fw-semibold text-decoration-none">
                                                @inv.InvoiceNumber
                                            </a>
                                        </td>
                                        <td>@inv.PoNumber</td>
                                        <td>@inv.CustomerName</td>
                                        <td class="text-end fw-semibold">@inv.GrandTotal.ToString("N0")</td>
                                        <td>@inv.InvoiceDate.ToString("dd-MM-yyyy")</td>
                                        <td>
                                            @if (daysOverdue > 30)
                                            {
                                                <span class="badge bg-danger">@daysOverdue days</span>
                                            }
                                            else if (daysOverdue > 15)
                                            {
                                                <span class="badge bg-warning text-dark">@daysOverdue days</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">@daysOverdue days</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.InvoiceId" class="btn btn-sm btn-outline-primary" title="View">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Attention Section: POs with Pending Quantities -->
@if (Model.PendingQuantityPOs.Any())
{
    <div class="row g-4 mb-4">
        <div class="col-12">
            <div class="card border-warning">
                <div class="card-header bg-warning bg-opacity-10">
                    <h3 class="card-title mb-0 text-warning">
                        <i class="fas fa-boxes-stacked me-2"></i>POs with Pending Quantities (@Model.PendingQuantityPOs.Count)
                    </h3>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr>
                                    <th>PO Number</th>
                                    <th>Internal Code</th>
                                    <th>Customer</th>
                                    <th class="text-end">PO Amount</th>
                                    <th>PO Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var po in Model.PendingQuantityPOs)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@po.PoId" class="fw-semibold text-decoration-none">
                                                @po.PoNumber
                                            </a>
                                        </td>
                                        <td>@po.InternalPoCode</td>
                                        <td>@po.CustomerName</td>
                                        <td class="text-end fw-semibold">@po.GrandTotal.ToString("N0")</td>
                                        <td>@(po.PoDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                                        <td>
                                            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@po.PoId" class="btn btn-sm btn-outline-primary" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Quick Actions -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title mb-0">
                    <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                </h3>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="PurchaseOrders" asp-action="Create" class="btn btn-primary w-100 py-3">
                            <i class="fas fa-plus-circle d-block mb-1 fs-4"></i>
                            <small>New PO</small>
                        </a>
                    </div>
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="Invoices" asp-action="Create" class="btn btn-success w-100 py-3">
                            <i class="fas fa-file-invoice d-block mb-1 fs-4"></i>
                            <small>New Invoice</small>
                        </a>
                    </div>
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="Quotations" asp-action="Create" class="btn btn-warning w-100 py-3 text-white">
                            <i class="fas fa-file-alt d-block mb-1 fs-4"></i>
                            <small>New Quotation</small>
                        </a>
                    </div>
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="DeliveryChallans" asp-action="Create" class="btn btn-info w-100 py-3 text-white">
                            <i class="fas fa-truck d-block mb-1 fs-4"></i>
                            <small>New DC</small>
                        </a>
                    </div>
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="Reports" asp-action="SalesReport" class="btn btn-dark w-100 py-3">
                            <i class="fas fa-chart-bar d-block mb-1 fs-4"></i>
                            <small>Sales Report</small>
                        </a>
                    </div>
                    <div class="col-md-4 col-lg-2">
                        <a asp-controller="Customers" asp-action="Index" class="btn btn-secondary w-100 py-3">
                            <i class="fas fa-users d-block mb-1 fs-4"></i>
                            <small>Customers</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/vendor/chart.min.js"></script>
    <script>
        // Color palette
        const purple = '#764ba2';
        const green = '#11998e';
        const orange = '#f7971e';
        const cyan = '#4facfe';
        const pink = '#f5576c';
        const darkPurple = '#667eea';

        // Month names helper
        const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

        // 1. Monthly Trend Chart (Bar + Line combo)
        var trendData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend));
        var trendLabels = trendData.map(d => monthNames[d.month - 1] + ' ' + d.year);
        var poCounts = trendData.map(d => d.poCount);
        var invCounts = trendData.map(d => d.invoiceCount);

        new Chart(document.getElementById('monthlyTrendChart'), {
            type: 'bar',
            data: {
                labels: trendLabels,
                datasets: [
                    {
                        label: 'Purchase Orders',
                        data: poCounts,
                        backgroundColor: 'rgba(118, 75, 162, 0.7)',
                        borderColor: purple,
                        borderWidth: 1,
                        borderRadius: 6,
                        order: 2
                    },
                    {
                        label: 'Invoices',
                        data: invCounts,
                        type: 'line',
                        borderColor: cyan,
                        backgroundColor: 'rgba(79, 172, 254, 0.1)',
                        borderWidth: 3,
                        pointBackgroundColor: cyan,
                        pointRadius: 5,
                        fill: true,
                        tension: 0.3,
                        order: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'top' }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                }
            }
        });

        // 2. PO Status Donut Chart
        new Chart(document.getElementById('poStatusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Completed', 'Pending'],
                datasets: [{
                    data: [@Model.CompletedPOs, @Model.PendingPOs],
                    backgroundColor: [green, orange],
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom' }
                }
            }
        });

        // 3. Top Customers Horizontal Bar Chart
        var topCustomers = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopCustomers));
        var custLabels = topCustomers.map(c => c.customerName.length > 20 ? c.customerName.substring(0, 20) + '...' : c.customerName);
        var custAmounts = topCustomers.map(c => c.totalAmount);

        new Chart(document.getElementById('topCustomersChart'), {
            type: 'bar',
            data: {
                labels: custLabels,
                datasets: [{
                    label: 'Total Amount',
                    data: custAmounts,
                    backgroundColor: [
                        'rgba(102, 126, 234, 0.8)',
                        'rgba(118, 75, 162, 0.8)',
                        'rgba(79, 172, 254, 0.8)',
                        'rgba(17, 153, 142, 0.8)',
                        'rgba(247, 151, 30, 0.8)'
                    ],
                    borderWidth: 0,
                    borderRadius: 6
                }]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ' ' + ctx.parsed.x.toLocaleString('en-IN');
                            }
                        }
                    }
                },
                scales: {
                    x: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(val) {
                                if (val >= 100000) return (val / 100000).toFixed(1) + 'L';
                                if (val >= 1000) return (val / 1000).toFixed(0) + 'K';
                                return val;
                            }
                        }
                    }
                }
            }
        });

        // 4. Payment Status Pie Chart
        new Chart(document.getElementById('paymentStatusChart'), {
            type: 'pie',
            data: {
                labels: ['Paid', 'Unpaid'],
                datasets: [{
                    data: [@Model.PaidAmount, @Model.UnpaidAmount],
                    backgroundColor: [green, pink],
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                return ctx.label + ': ' + ctx.parsed.toLocaleString('en-IN');
                            }
                        }
                    }
                }
            }
        });
    </script>
}
