@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    var completionRate = Model.TotalPOs > 0 ? (double)Model.CompletedPOs / Model.TotalPOs * 100 : 0;
    var paidRate = Model.TotalInvoices > 0 ? (double)Model.PaidInvoices / Model.TotalInvoices * 100 : 0;
    var userName = User.Identity?.Name ?? "User";
    var currentMonth = DateTime.Now.ToString("MMMM yyyy");
}

<style>
    .dashboard-card {
        border: none;
        border-radius: 12px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        overflow: hidden;
    }
    .dashboard-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.12) !important;
    }
    .stat-card {
        padding: 20px 22px;
        border-radius: 12px;
        position: relative;
        overflow: hidden;
        min-height: 130px;
    }
    .stat-card::before {
        content: '';
        position: absolute;
        top: -30px;
        right: -30px;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: rgba(255,255,255,0.12);
    }
    .stat-card .stat-icon {
        width: 48px;
        height: 48px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.2);
        font-size: 1.25rem;
    }
    .stat-card .stat-value {
        font-size: 1.65rem;
        font-weight: 700;
        line-height: 1.2;
    }
    .stat-card .stat-label {
        font-size: 0.78rem;
        opacity: 0.85;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 500;
    }
    .stat-card .stat-sub {
        font-size: 0.75rem;
        opacity: 0.75;
        margin-top: 4px;
    }

    .bg-po { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: #fff; }
    .bg-completed { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); color: #fff; }
    .bg-invoice { background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: #fff; }
    .bg-unpaid { background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: #fff; }
    .bg-monthly { background: linear-gradient(135deg, #fa709a 0%, #fee140 100%); color: #fff; }
    .bg-amount { background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%); color: #fff; }

    .welcome-banner {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 14px;
        padding: 24px 28px;
        color: #fff;
        position: relative;
        overflow: hidden;
    }
    .welcome-banner::after {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 300px;
        height: 300px;
        border-radius: 50%;
        background: rgba(255,255,255,0.06);
    }
    .welcome-banner h2 { font-weight: 700; font-size: 1.5rem; margin-bottom: 4px; }
    .welcome-banner p { opacity: 0.85; margin-bottom: 0; font-size: 0.9rem; }

    .quick-action-btn {
        border: 2px dashed #dee2e6;
        border-radius: 12px;
        padding: 18px 16px;
        text-align: center;
        transition: all 0.2s ease;
        text-decoration: none;
        display: block;
        color: #495057;
        background: #fff;
    }
    .quick-action-btn:hover {
        border-color: #667eea;
        background: #f8f9ff;
        color: #667eea;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.15);
    }
    .quick-action-btn .action-icon {
        width: 44px;
        height: 44px;
        border-radius: 10px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.15rem;
        margin-bottom: 8px;
        color: #fff;
    }
    .quick-action-btn .action-label {
        font-weight: 600;
        font-size: 0.82rem;
        display: block;
    }

    .progress-thin { height: 6px; border-radius: 3px; }

    .month-highlight {
        background: linear-gradient(135deg, #f8f9ff 0%, #fff5f5 100%);
        border: 1px solid #eee;
        border-radius: 12px;
        padding: 18px 20px;
    }
    .month-highlight .month-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #333;
    }
    .month-highlight .month-label {
        font-size: 0.75rem;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .customer-rank {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.75rem;
    }
    .rank-1 { background: linear-gradient(135deg, #f7971e, #ffd200); color: #fff; }
    .rank-2 { background: linear-gradient(135deg, #bdc3c7, #95a5a6); color: #fff; }
    .rank-3 { background: linear-gradient(135deg, #cd7f32, #a0522d); color: #fff; }
    .rank-other { background: #e9ecef; color: #6c757d; }
</style>

<!-- Welcome Banner -->
<div class="welcome-banner mb-4">
    <div class="d-flex justify-content-between align-items-center position-relative" style="z-index:1;">
        <div>
            <h2><i class="fas fa-chart-line me-2"></i>Welcome back, @userName!</h2>
            <p>Here's your business overview for @currentMonth</p>
        </div>
        <div class="text-end d-none d-md-block">
            <div class="fw-bold fs-5">@DateTime.Now.ToString("dddd")</div>
            <div class="opacity-75">@DateTime.Now.ToString("dd MMM yyyy")</div>
        </div>
    </div>
</div>

<!-- KPI Stat Cards - Row 1: Counts -->
<div class="row g-3 mb-3">
    <div class="col-6 col-lg-3">
        <div class="stat-card bg-po shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="stat-icon"><i class="fas fa-file-alt"></i></div>
                <span class="stat-sub"><i class="fas fa-clock me-1"></i>@Model.PendingPOs Pending</span>
            </div>
            <div class="stat-value">@Model.TotalPOs</div>
            <div class="stat-label">Purchase Orders</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card bg-completed shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="stat-icon"><i class="fas fa-check-double"></i></div>
                <span class="stat-sub">@completionRate.ToString("N0")%</span>
            </div>
            <div class="stat-value">@Model.CompletedPOs</div>
            <div class="stat-label">Completed POs</div>
            <div class="progress progress-thin mt-2" style="background: rgba(255,255,255,0.25);">
                <div class="progress-bar bg-white" style="width: @completionRate%; opacity: 0.8;"></div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card bg-invoice shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="stat-icon"><i class="fas fa-file-invoice"></i></div>
                <span class="stat-sub"><i class="fas fa-check me-1"></i>@Model.PaidInvoices Paid</span>
            </div>
            <div class="stat-value">@Model.TotalInvoices</div>
            <div class="stat-label">Total Invoices</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card bg-unpaid shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <div class="stat-icon"><i class="fas fa-exclamation-circle"></i></div>
                <span class="stat-sub">Needs Attention</span>
            </div>
            <div class="stat-value">@Model.UnpaidInvoices</div>
            <div class="stat-label">Unpaid Invoices</div>
        </div>
    </div>
</div>

<!-- KPI Stat Cards - Row 2: Amounts -->
<div class="row g-3 mb-4">
    <div class="col-12 col-md-4">
        <div class="stat-card bg-amount shadow-sm">
            <div class="d-flex align-items-center mb-2">
                <div class="stat-icon me-3"><i class="fas fa-indian-rupee-sign"></i></div>
                <div>
                    <div class="stat-label">Total PO Value</div>
                    <div class="stat-value">@Model.TotalPoAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="stat-card shadow-sm" style="background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%); color: #fff;">
            <div class="d-flex align-items-center mb-2">
                <div class="stat-icon me-3"><i class="fas fa-indian-rupee-sign"></i></div>
                <div>
                    <div class="stat-label">Total Invoice Value</div>
                    <div class="stat-value">@Model.TotalInvoiceAmount.ToString("N0")</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="stat-card shadow-sm" style="background: linear-gradient(135deg, #ff6a88 0%, #ff99ac 100%); color: #fff;">
            <div class="d-flex align-items-center mb-2">
                <div class="stat-icon me-3"><i class="fas fa-indian-rupee-sign"></i></div>
                <div>
                    <div class="stat-label">Unpaid Amount</div>
                    <div class="stat-value">@Model.UnpaidInvoiceAmount.ToString("N0")</div>
                </div>
            </div>
            <div class="progress progress-thin mt-1" style="background: rgba(255,255,255,0.25);">
                <div class="progress-bar bg-white" style="width: @paidRate%; opacity: 0.8;"></div>
            </div>
            <div class="stat-sub">@paidRate.ToString("N0")% collection rate</div>
        </div>
    </div>
</div>

<!-- This Month Summary + Quick Actions -->
<div class="row g-3 mb-4">
    <!-- This Month Summary -->
    <div class="col-12 col-lg-6">
        <div class="card dashboard-card shadow-sm h-100">
            <div class="card-header bg-white border-bottom-0 pb-0">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="fas fa-calendar-alt me-2 text-primary"></i>This Month <small class="text-muted fw-normal">(@currentMonth)</small>
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="month-highlight text-center">
                            <div class="month-value text-primary">@Model.ThisMonthPOs</div>
                            <div class="month-label">New POs</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="month-highlight text-center">
                            <div class="month-value text-success">@Model.ThisMonthInvoices</div>
                            <div class="month-label">New Invoices</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="month-highlight text-center">
                            <div class="month-value" style="color: #764ba2; font-size: 1.15rem;">@Model.ThisMonthPoAmount.ToString("N0")</div>
                            <div class="month-label">PO Value</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="month-highlight text-center">
                            <div class="month-value" style="color: #11998e; font-size: 1.15rem;">@Model.ThisMonthInvoiceAmount.ToString("N0")</div>
                            <div class="month-label">Invoice Value</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="col-12 col-lg-6">
        <div class="card dashboard-card shadow-sm h-100">
            <div class="card-header bg-white border-bottom-0 pb-0">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="fas fa-bolt me-2 text-warning"></i>Quick Actions
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-6 col-md-3">
                        <a asp-controller="PurchaseOrders" asp-action="Create" class="quick-action-btn">
                            <div class="action-icon bg-po mx-auto"><i class="fas fa-plus"></i></div>
                            <span class="action-label">New PO</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="Invoices" asp-action="Create" class="quick-action-btn">
                            <div class="action-icon mx-auto" style="background: linear-gradient(135deg, #11998e, #38ef7d);"><i class="fas fa-file-invoice"></i></div>
                            <span class="action-label">New Invoice</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="DeliveryChallans" asp-action="Create" class="quick-action-btn">
                            <div class="action-icon mx-auto" style="background: linear-gradient(135deg, #4facfe, #00f2fe);"><i class="fas fa-truck"></i></div>
                            <span class="action-label">New DC</span>
                        </a>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="Quotations" asp-action="Create" class="quick-action-btn">
                            <div class="action-icon mx-auto" style="background: linear-gradient(135deg, #fa709a, #fee140);"><i class="fas fa-quote-right"></i></div>
                            <span class="action-label">New Quote</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent POs + Recent Invoices -->
<div class="row g-3 mb-4">
    <!-- Recent Purchase Orders -->
    <div class="col-12 col-xl-6">
        <div class="card dashboard-card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="fas fa-file-alt me-2 text-primary"></i>Recent Purchase Orders
                </h5>
                <a asp-controller="PurchaseOrders" asp-action="Index" class="btn btn-sm btn-outline-primary rounded-pill">
                    View All <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentPOs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">PO Number</th>
                                    <th>Customer</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-center">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var po in Model.RecentPOs)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <a asp-controller="PurchaseOrders" asp-action="Details" asp-route-id="@po.PoId" class="fw-semibold text-decoration-none">
                                                @po.PoNumber
                                            </a>
                                            <br /><small class="text-muted">@po.CreatedDate.ToString("dd-MMM-yy")</small>
                                        </td>
                                        <td>
                                            <span class="fw-medium">@po.CustomerName</span>
                                        </td>
                                        <td class="text-end fw-semibold">@po.PoAmount.ToString("N0")</td>
                                        <td class="text-center">
                                            @if (po.IsCompleted)
                                            {
                                                <span class="badge bg-success rounded-pill px-2"><i class="fas fa-check me-1"></i>Done</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark rounded-pill px-2"><i class="fas fa-clock me-1"></i>Open</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-inbox fa-3x text-muted mb-2 d-block"></i>
                        <p class="text-muted mb-2">No purchase orders yet</p>
                        <a asp-controller="PurchaseOrders" asp-action="Create" class="btn btn-sm btn-primary rounded-pill">
                            <i class="fas fa-plus me-1"></i>Create First PO
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Recent Invoices -->
    <div class="col-12 col-xl-6">
        <div class="card dashboard-card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0 fw-bold">
                    <i class="fas fa-file-invoice me-2 text-success"></i>Recent Invoices
                </h5>
                <a asp-controller="Invoices" asp-action="Index" class="btn btn-sm btn-outline-success rounded-pill">
                    View All <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model.RecentInvoices.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Invoice No</th>
                                    <th>Customer</th>
                                    <th class="text-end">Amount</th>
                                    <th class="text-center">Payment</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var inv in Model.RecentInvoices)
                                {
                                    <tr>
                                        <td class="ps-3">
                                            <a asp-controller="Invoices" asp-action="Details" asp-route-id="@inv.InvoiceId" class="fw-semibold text-decoration-none">
                                                @inv.InvoiceNumber
                                            </a>
                                            <br /><small class="text-muted">@inv.InvoiceDate.ToString("dd-MMM-yy")</small>
                                        </td>
                                        <td>
                                            <span class="fw-medium">@inv.CustomerName</span>
                                            <br /><small class="text-muted">@inv.PoNumber</small>
                                        </td>
                                        <td class="text-end fw-semibold">@inv.GrandTotal.ToString("N0")</td>
                                        <td class="text-center">
                                            @if (inv.IsPaid)
                                            {
                                                <span class="badge bg-success rounded-pill px-2"><i class="fas fa-check me-1"></i>Paid</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger rounded-pill px-2"><i class="fas fa-times me-1"></i>Unpaid</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-4">
                        <i class="fas fa-file-invoice fa-3x text-muted mb-2 d-block"></i>
                        <p class="text-muted mb-2">No invoices yet</p>
                        <a asp-controller="Invoices" asp-action="Create" class="btn btn-sm btn-success rounded-pill">
                            <i class="fas fa-plus me-1"></i>Create First Invoice
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Top Customers -->
@if (Model.TopCustomers.Any())
{
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="card dashboard-card shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0 fw-bold">
                        <i class="fas fa-trophy me-2 text-warning"></i>Top Customers <small class="text-muted fw-normal">(by PO value)</small>
                    </h5>
                    <a asp-controller="Customers" asp-action="Index" class="btn btn-sm btn-outline-warning rounded-pill">
                        All Customers <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3" style="width: 50px;">#</th>
                                    <th>Customer</th>
                                    <th class="text-center">POs</th>
                                    <th class="text-center">Invoices</th>
                                    <th class="text-end pe-3">Total Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopCustomers.Count; i++)
                                {
                                    var cust = Model.TopCustomers[i];
                                    var rankClass = i switch { 0 => "rank-1", 1 => "rank-2", 2 => "rank-3", _ => "rank-other" };
                                    <tr>
                                        <td class="ps-3">
                                            <span class="customer-rank @rankClass">@(i + 1)</span>
                                        </td>
                                        <td class="fw-semibold">@cust.CustomerName</td>
                                        <td class="text-center">
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">@cust.PoCount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-success bg-opacity-10 text-success rounded-pill">@cust.InvoiceCount</span>
                                        </td>
                                        <td class="text-end pe-3 fw-bold">@cust.TotalAmount.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
