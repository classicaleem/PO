@model PurchaseOrderViewModel
@{
    ViewData["Title"] = "Edit Purchase Order";
}

<style>
    .po-sticky-summary {
        position: sticky;
        top: 70px;
    }
    .po-form .form-control, .po-form .form-select {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        border-radius: 8px;
    }
    .po-items-table .form-control {
        padding: 0.4rem 0.6rem;
        font-size: 0.875rem;
        border-radius: 6px;
    }
    .po-items-table th {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.6rem 0.5rem;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
    }
    .po-items-table td {
        padding: 0.5rem;
        vertical-align: middle;
    }
    .po-items-table tbody tr:hover {
        background-color: rgba(102, 126, 234, 0.04);
    }
    .po-items-table .item-total-cell {
        background-color: #f0f4ff;
        font-weight: 600;
    }
    .customer-info-card {
        background: linear-gradient(135deg, #f8f9ff 0%, #f0f4ff 100%);
        border: 1px solid rgba(102, 126, 234, 0.15);
        border-radius: 10px;
        padding: 1rem;
    }
    .customer-info-card .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        margin-bottom: 0.15rem;
    }
    .customer-info-card .info-value {
        font-size: 0.9rem;
        font-weight: 500;
        color: #333;
    }
    .summary-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.4rem 0;
    }
    .summary-row.total-row {
        border-top: 2px solid #667eea;
        margin-top: 0.5rem;
        padding-top: 0.75rem;
    }
    .add-item-area {
        border: 2px dashed rgba(102, 126, 234, 0.3);
        border-radius: 8px;
        padding: 0.75rem;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }
    .add-item-area:hover {
        border-color: #667eea;
        background-color: rgba(102, 126, 234, 0.05);
    }
    .section-title {
        font-size: 0.95rem;
        font-weight: 600;
        color: #333;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    .section-title i {
        color: #667eea;
    }
    .btn-remove-item {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        padding: 0;
        transition: all 0.2s;
    }
    .btn-remove-item:hover {
        background-color: #dc3545;
        color: white;
        transform: scale(1.1);
    }
</style>

<!-- Page Header -->
<div class="page-header">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1><i class="fas fa-edit me-3"></i>Edit Purchase Order</h1>
            <p class="mb-0 opacity-75">@Model.InternalPoCode — @Model.PoNumber</p>
        </div>
        <a asp-action="Index" class="btn btn-light">
            <i class="fas fa-arrow-left me-2"></i>Back to List
        </a>
    </div>
</div>

<form asp-action="Edit" method="post" id="poForm" class="po-form">
    <input type="hidden" asp-for="PoId" />
    <input type="hidden" asp-for="InternalPoCode" />
    <div asp-validation-summary="All" class="alert alert-danger" style="display:none;"></div>

    <div class="row">
        <!-- Left Column: PO Header + Items -->
        <div class="col-lg-8">

            <!-- PO Details Card -->
            <div class="card mb-3">
                <div class="card-header py-2">
                    <span class="section-title"><i class="fas fa-file-alt"></i> PO Details</span>
                </div>
                <div class="card-body py-3">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="InternalPoCode" class="form-label small fw-semibold text-muted">Internal PO Code</label>
                            <input value="@Model.InternalPoCode" class="form-control" readonly style="background-color: #f0f4ff; font-weight: 600; color: #667eea;" />
                        </div>
                        <div class="col-md-8">
                            <label asp-for="PoNumber" class="form-label small fw-semibold">PO Number <span class="text-danger">*</span></label>
                            <input asp-for="PoNumber" class="form-control" />
                            <span asp-validation-for="PoNumber" class="text-danger small"></span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Customer Card -->
            <div class="card mb-3">
                <div class="card-header py-2">
                    <span class="section-title"><i class="fas fa-user-tie"></i> Customer</span>
                </div>
                <div class="card-body py-3">
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="CustomerId" class="form-label small fw-semibold">Select Customer <span class="text-danger">*</span></label>
                            <select asp-for="CustomerId" asp-items="Model.Customers" class="form-select select2-customer" id="customerSelect">
                                <option value="">-- Search or select a customer --</option>
                            </select>
                            <span asp-validation-for="CustomerId" class="text-danger small"></span>
                        </div>
                        <div class="col-12" id="customerDetailsDiv" @(Model.CustomerId > 0 ? "" : "style=display:none;")>
                            <div class="customer-info-card">
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <div class="info-label">Customer Name</div>
                                        <div class="info-value" id="custName">@(Model.CustomerName ?? "-")</div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="info-label">GST Number</div>
                                        <div class="info-value" id="custGst">@(Model.CustomerGstNumber ?? "N/A")</div>
                                    </div>
                                    <div class="col-12">
                                        <div class="info-label">Address</div>
                                        <div class="info-value" id="custAddress">@(Model.CustomerAddress ?? "-")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Dates & Status Card -->
            <div class="card mb-3">
                <div class="card-header py-2">
                    <span class="section-title"><i class="fas fa-calendar-alt"></i> Dates & Status</span>
                </div>
                <div class="card-body py-3">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label asp-for="PoDate" class="form-label small fw-semibold">PO Date <span class="text-danger">*</span></label>
                            <input asp-for="PoDate" class="form-control" type="date" lang="en-GB" />
                            <span asp-validation-for="PoDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="StartDate" class="form-label small fw-semibold text-muted">Start Date</label>
                            <input asp-for="StartDate" class="form-control" type="date" lang="en-GB" />
                        </div>
                        <div class="col-md-4">
                            <label asp-for="EndDate" class="form-label small fw-semibold text-muted">End Date</label>
                            <input asp-for="EndDate" class="form-control" type="date" lang="en-GB" />
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="IsCompleted" class="form-check-input" />
                                <label asp-for="IsCompleted" class="form-check-label fw-semibold">Mark as Completed</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Items Card -->
            <div class="card mb-3">
                <div class="card-header py-2 d-flex justify-content-between align-items-center">
                    <span class="section-title"><i class="fas fa-boxes-stacked"></i> Line Items</span>
                    <span class="badge bg-primary" id="itemCountBadge">@Model.Items.Count items</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0 po-items-table" id="itemsTable">
                            <thead>
                                <tr>
                                    <th style="width: 4%;" class="text-center">#</th>
                                    <th style="width: 34%;">Item Description <span class="text-warning">*</span></th>
                                    <th style="width: 12%;">HSN Code</th>
                                    <th style="width: 14%;" class="text-center">Qty <span class="text-warning">*</span></th>
                                    <th style="width: 16%;" class="text-end">Unit Price <span class="text-warning">*</span></th>
                                    <th style="width: 16%;" class="text-end">Line Total</th>
                                    <th style="width: 4%;" class="text-center"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsBody">
                                @for (int i = 0; i < Model.Items.Count; i++)
                                {
                                    var item = Model.Items[i];
                                    <tr class="item-row">
                                        <td class="text-center line-number fw-semibold text-muted">@(i + 1)</td>
                                        <td>
                                            <input type="hidden" name="Items[@i].PoItemId" value="@item.PoItemId" />
                                            <input type="hidden" name="Items[@i].LineNumber" value="@(i + 1)" />
                                            <input type="text" name="Items[@i].ItemDescription" value="@item.ItemDescription"
                                                   class="form-control item-description" placeholder="Enter item description" />
                                        </td>
                                        <td>
                                            <input type="text" name="Items[@i].HsnCode" value="@item.HsnCode"
                                                   class="form-control item-hsn" placeholder="HSN" maxlength="10" />
                                        </td>
                                        <td>
                                            <input type="number" name="Items[@i].Quantity" value="@item.Quantity"
                                                   class="form-control item-quantity text-center" min="1" step="1"
                                                   onkeypress="return event.charCode >= 48 && event.charCode <= 57" />
                                        </td>
                                        <td>
                                            <input type="number" name="Items[@i].UnitPrice" value="@item.UnitPrice"
                                                   class="form-control item-price text-end" min="0.01" step="0.01" />
                                        </td>
                                        <td>
                                            <input type="text" class="form-control item-total text-end item-total-cell" value="@item.LineTotal.ToString("N2")" readonly />
                                        </td>
                                        <td class="text-center">
                                            <button type="button" class="btn btn-outline-danger btn-sm btn-remove-item remove-item-btn" title="Remove item">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    <div class="p-3 pt-2">
                        <div class="add-item-area" id="addItemBtn">
                            <i class="fas fa-plus me-2 text-primary"></i>
                            <span class="text-primary fw-semibold">Add New Item</span>
                            <span class="text-muted small ms-2">(max 10 items)</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Sticky Summary + Actions -->
        <div class="col-lg-4">
            <div class="po-sticky-summary">
                <!-- Summary Card -->
                <div class="card mb-3">
                    <div class="card-header py-2" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                        <span class="section-title text-white"><i class="fas fa-calculator" style="color: white;"></i> PO Summary</span>
                    </div>
                    <div class="card-body">
                        <div class="summary-row">
                            <span class="text-muted">Total Items</span>
                            <span id="totalItems" class="fw-bold badge bg-primary">@Model.Items.Count</span>
                        </div>
                        <hr class="my-2">
                        <div class="summary-row">
                            <span class="fw-semibold">Sub Total</span>
                            <span id="poAmount" class="fw-bold">₹@Model.PoAmount.ToString("N2")</span>
                        </div>
                        <div class="summary-row small">
                            <span class="text-muted">CGST (<span id="cgstDisplay">@Model.CgstPercent</span>%)</span>
                            <span id="cgstAmount" class="text-muted">₹@((Model.PoAmount * Model.CgstPercent / 100).ToString("N2"))</span>
                        </div>
                        <div class="summary-row small">
                            <span class="text-muted">SGST (<span id="sgstDisplay">@Model.SgstPercent</span>%)</span>
                            <span id="sgstAmount" class="text-muted">₹@((Model.PoAmount * Model.SgstPercent / 100).ToString("N2"))</span>
                        </div>
                        <div class="summary-row small">
                            <span class="text-muted">IGST (<span id="igstDisplay">@Model.IgstPercent</span>%)</span>
                            <span id="igstAmount" class="text-muted">₹@((Model.PoAmount * Model.IgstPercent / 100).ToString("N2"))</span>
                        </div>
                        <div class="summary-row small">
                            <span class="text-muted">Round Off</span>
                            <span id="roundOffAmount" class="text-muted">₹@Model.RoundOff.ToString("N2")</span>
                        </div>
                        <div class="summary-row total-row">
                            <span class="h6 mb-0 fw-bold">Grand Total</span>
                            <span id="grandTotal" class="h5 mb-0 fw-bold text-success">₹@Model.GrandTotal.ToString("N2")</span>
                        </div>

                        <input type="hidden" asp-for="PoAmount" id="poAmountInput" />
                        <input type="hidden" asp-for="CgstPercent" id="cgstInput" />
                        <input type="hidden" asp-for="SgstPercent" id="sgstInput" />
                        <input type="hidden" asp-for="IgstPercent" id="igstInput" />
                        <input type="hidden" asp-for="TaxAmount" id="taxAmountInput" />
                        <input type="hidden" asp-for="RoundOff" id="roundOffInput" />
                        <input type="hidden" asp-for="GrandTotal" id="grandTotalInput" />
                    </div>
                </div>

                <!-- Action Card -->
                <div class="card">
                    <div class="card-body py-3">
                        <button type="submit" class="btn btn-primary w-100 py-2 mb-2 fw-semibold">
                            <i class="fas fa-save me-2"></i>Update Purchase Order
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="fas fa-times me-2"></i>Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $(document).ready(function () {
            $('.select2-customer').select2({ theme: 'bootstrap-5', placeholder: 'Search...', allowClear: true });

            $('#customerSelect').on('change', function () {
                var customerId = $(this).val();
                if (customerId) {
                    $.get('@Url.Action("GetCustomerDetails", "Customers")', { id: customerId }, function (data) {
                        $('#customerDetailsDiv').slideDown(200);
                        $('#custName').text(data.customerName || '-');
                        $('#custAddress').text(data.address || '-');
                        $('#custGst').text(data.gstNumber || 'N/A');

                        $.get('@Url.Action("GetTaxDefaults", "Customers")', { state: data.state }, function (taxData) {
                            $('#cgstInput').val(taxData.cgst);
                            $('#sgstInput').val(taxData.sgst);
                            $('#igstInput').val(taxData.igst);
                            $('#cgstDisplay').text(taxData.cgst);
                            $('#sgstDisplay').text(taxData.sgst);
                            $('#igstDisplay').text(taxData.igst);
                            calculateTotals();
                        });
                    });
                } else {
                    $('#customerDetailsDiv').slideUp(200);
                    $('#custName').text('-');
                    $('#custAddress').text('-');
                    $('#custGst').text('-');
                    $('#cgstInput').val(0); $('#sgstInput').val(0); $('#igstInput').val(0);
                    $('#cgstDisplay').text(0); $('#sgstDisplay').text(0); $('#igstDisplay').text(0);
                    calculateTotals();
                }
            });

            function calculateTotals() {
                var totalAmount = 0, itemCount = 0;

                $('#itemsBody tr.item-row').each(function (index) {
                    var qty = parseFloat($(this).find('.item-quantity').val()) || 0;
                    var price = parseFloat($(this).find('.item-price').val()) || 0;
                    var lineTotal = qty * price;
                    $(this).find('.item-total').val(lineTotal.toFixed(2));

                    if ($(this).find('.item-description').val().trim() !== '') {
                        totalAmount += lineTotal;
                        if (qty > 0) itemCount++;
                    }

                    $(this).find('.line-number').text(index + 1);
                    $(this).find('input[name*="LineNumber"]').val(index + 1);
                    $(this).find('input').each(function () {
                        var name = $(this).attr('name');
                        if (name) $(this).attr('name', name.replace(/\[\d+\]/, '[' + index + ']'));
                    });
                });

                $('#totalItems').text(itemCount);
                $('#itemCountBadge').text(itemCount + ' item' + (itemCount !== 1 ? 's' : ''));
                $('#poAmount').text('₹' + totalAmount.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
                $('#poAmountInput').val(totalAmount.toFixed(2));

                var cgst = parseFloat($('#cgstInput').val()) || 0;
                var sgst = parseFloat($('#sgstInput').val()) || 0;
                var igst = parseFloat($('#igstInput').val()) || 0;

                var cgstAmt = totalAmount * (cgst / 100);
                var sgstAmt = totalAmount * (sgst / 100);
                var igstAmt = totalAmount * (igst / 100);
                var totalTax = cgstAmt + sgstAmt + igstAmt;
                var totalWithTax = totalAmount + totalTax;
                var grandTotal = Math.round(totalWithTax);
                var roundOff = grandTotal - totalWithTax;

                $('#cgstAmount').text('₹' + cgstAmt.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
                $('#sgstAmount').text('₹' + sgstAmt.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
                $('#igstAmount').text('₹' + igstAmt.toLocaleString('en-IN', { minimumFractionDigits: 2 }));
                $('#roundOffAmount').text('₹' + roundOff.toFixed(2));
                $('#grandTotal').text('₹' + grandTotal.toLocaleString('en-IN', { minimumFractionDigits: 2 }));

                $('#taxAmountInput').val(totalTax.toFixed(2));
                $('#roundOffInput').val(roundOff.toFixed(2));
                $('#grandTotalInput').val(grandTotal.toFixed(2));
            }

            $(document).on('input', '.item-quantity, .item-price', calculateTotals);

            $(document).on('keydown', '.item-price', function (e) {
                if (e.key === 'Tab' && !e.shiftKey) {
                    var $row = $(this).closest('tr');
                    if ($row.is('#itemsBody tr.item-row:last-child')) {
                        var rowCount = $('#itemsBody tr.item-row').length;
                        if (rowCount < 10) {
                            e.preventDefault();
                            addNewRow();
                            $('#itemsBody tr.item-row:last-child .item-description').focus();
                        }
                    }
                }
            });

            function addNewRow() {
                var rowCount = $('#itemsBody tr.item-row').length;
                if (rowCount >= 10) { toastr.warning('Maximum 10 items allowed per PO'); return; }
                var newRow = `
                    <tr class="item-row">
                        <td class="text-center line-number fw-semibold text-muted">${rowCount + 1}</td>
                        <td>
                            <input type="hidden" name="Items[${rowCount}].PoItemId" value="0" />
                            <input type="hidden" name="Items[${rowCount}].LineNumber" value="${rowCount + 1}" />
                            <input type="text" name="Items[${rowCount}].ItemDescription"
                                   class="form-control item-description" placeholder="Enter item description" />
                        </td>
                        <td>
                            <input type="text" name="Items[${rowCount}].HsnCode"
                                   class="form-control item-hsn" placeholder="HSN" maxlength="10" />
                        </td>
                        <td>
                            <input type="number" name="Items[${rowCount}].Quantity"
                                   class="form-control item-quantity text-center" min="1" step="1"
                                   onkeypress="return event.charCode >= 48 && event.charCode <= 57" placeholder="0" />
                        </td>
                        <td>
                            <input type="number" name="Items[${rowCount}].UnitPrice"
                                   class="form-control item-price text-end" min="0.01" step="0.01" placeholder="0.00" />
                        </td>
                        <td>
                            <input type="text" class="form-control item-total text-end item-total-cell" value="0.00" readonly />
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-outline-danger btn-sm btn-remove-item remove-item-btn" title="Remove item">
                                <i class="fas fa-times"></i>
                            </button>
                        </td>
                    </tr>`;
                $('#itemsBody').append(newRow);
                calculateTotals();
            }

            $('#addItemBtn').on('click', function () {
                addNewRow();
                $('#itemsBody tr.item-row:last-child .item-description').focus();
            });

            $(document).on('click', '.remove-item-btn', function () {
                if ($('#itemsBody tr.item-row').length <= 1) { toastr.warning('At least one item required'); return; }
                $(this).closest('tr').fadeOut(200, function () {
                    $(this).remove();
                    calculateTotals();
                });
            });

            calculateTotals();

            if ($('.field-validation-error').length > 0 || $('.validation-summary-errors').length > 0) {
                $('.alert-danger').show();
            }
        });
    </script>
}
